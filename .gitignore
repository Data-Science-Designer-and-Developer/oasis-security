# =============================================================================
# Oasis Security —  .gitignore
# =============================================================================

# ── ENVIRONNEMENTS ────────────────────────────────────────────────────────────
venv/
.venv/
env/
.env

# ── SECRETS ───────────────────────────────────────────────────────────────────
secrets/
secrets.yaml
config/secrets/

# ── PYTHON ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.so
*.egg*
dist/
build/
*.whl

# ── NOTEBOOKS ─────────────────────────────────────────────────────────────────
.ipynb_checkpoints/

# ── DATA ──────────────────────────────────────────────────────────────────────
data/raw/
*.csv
*.parquet

# ── ML / MLOPS ────────────────────────────────────────────────────────────────
mlruns/
mlflow.db
*.pkl
*.joblib
models/*.pkl
models/*.json

# ── LOGS ──────────────────────────────────────────────────────────────────────
*.log
logs/

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── TESTS ─────────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/